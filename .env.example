# MongoDB
ATLAS_URI="mongodb+srv://user:pass@cluster.mongodb.net/"
# Optional: separate DB for student data (e.g. Kable Career)
# ATLAS_URI_TEST="mongodb+srv://..."

# Admin login (used by seed script: npm run seed creates this user in kableadmin)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-secure-password

# Server
PORT=5001

# Optional: require ?secret= or body.secret for /api/cron/check-overdue
# CRON_SECRET=your-secret

# ---- Overdue emails: choose one method ----

# Option A: Microsoft Graph (OAuth 2.0) – recommended for Office 365
# Get these from Azure Portal > App registrations > Your app
MS_CLIENT_ID=your-application-client-id
MS_CLIENT_SECRET=your-client-secret-value
MS_TENANT_ID=your-tenant-id
MS_SENDER_UPN=MKohlmorgen@kableacademy.com

# Option B: SMTP (e.g. Outlook/Gmail) – used if Graph vars above are not set
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@domain.com
# SMTP_PASS=your-password-or-app-password
# SMTP_FROM=your-email@domain.com

